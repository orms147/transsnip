# ─── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging / build artifacts
build/
dist/
*.egg-info/
*.egg
*.spec.bak

# ─── Tooling caches ──────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.log

# ─── Editors / OS ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~
Thumbs.db
.DS_Store

# ─── Local runtime data (settings, cache, history, logs) ──────────────────
# API keys live in Windows Credential Manager (keyring), never on disk here.
.transsnip-local/

# ─── Secrets (belt-and-braces — keys should never be committed) ───────────
.env
.env.*
*.pem
*.key
secrets.json

# ─── Bundled OCR models (~42 MB of ONNX binary blobs) ─────────────────────
# Fetched via `python scripts/fetch_models.py` (see docs/mentor/27 + 42).
# Not committed — they bloat the repo and the .exe bundles them at build time.
resources/models/*.onnx
resources/models/*.txt

# ─── Claude Code tooling (internal — not shared on the public repo) ───────
.claude/

# ─── Mentor learning docs (kept local-only) ───────────────────────────────
docs/

# ─── Scratch / diagnostics (temp files created while developing) ──────────
_diag_*.py
_shot*.png
build_log.txt